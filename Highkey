UserInputService.InputBegan:Connect(function(input, processed)
    
    if input.KeyCode == Enum.KeyCode.M and not processed then
        config.guiVisible = not config.guiVisible

        if config.guiVisible then
            
            MainFrame.Visible = true
            ControlCanvas.GroupTransparency = 1
            TweenService:Create(
                ControlCanvas,
                TweenInfo.new(0.3),
                {GroupTransparency = 0}
            ):Play()
        else
            
            local tween = TweenService:Create(
                ControlCanvas,
                TweenInfo.new(0.3),
                {GroupTransparency = 1}
            )
            tween:Play()
            tween.Completed:Connect(function()
                if not config.guiVisible then 
                    MainFrame.Visible = false
                end
            end)
        end
    end

    
    if input.UserInputType == Enum.UserInputType.Keyboard then
        local k = keyObjects[input.KeyCode.Name]
        if k then 
            k.BackgroundColor3 = config.lavender 
            k.TextColor3 = Color3.new(0, 0, 0) 
        end
    elseif input.UserInputType == Enum.UserInputType.MouseButton1 then 
        LMB.BackgroundColor3 = config.lavender
    elseif input.UserInputType == Enum.UserInputType.MouseButton2 then 
        RMB.BackgroundColor3 = config.lavender
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Keyboard then
        local k = keyObjects[input.KeyCode.Name]
        if k then k.BackgroundColor3 = config.key_bg k.TextColor3 = Color3.new(1,1,1) end
    elseif input.UserInputType == Enum.UserInputType.MouseButton1 then LMB.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    elseif input.UserInputType == Enum.UserInputType.MouseButton2 then RMB.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end
end)

