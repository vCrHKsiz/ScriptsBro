local dragging = false
local resizing = false
local dragStart, startPos
local resizeStart, startSize
local minSize = Vector2.new(200, 150)

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local mousePos = input.Position
        local framePos = MainFrame.AbsolutePosition
        local frameSize = MainFrame.AbsoluteSize
        if mousePos.X > framePos.X + frameSize.X - 15 and
           mousePos.Y > framePos.Y + frameSize.Y - 15 then
            resizing = true
            resizeStart = mousePos
            startSize = frameSize
        else
            dragging = true
            dragStart = mousePos
            startPos = MainFrame.Position
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        if resizing then
            local delta = input.Position - resizeStart
            local newWidth = math.max(minSize.X, startSize.X + delta.X)
            local newHeight = math.max(minSize.Y, startSize.Y + delta.Y)
            MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
        elseif dragging then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            ProfilePanel.Position = UDim2.new(MainFrame.Position.X.Scale, MainFrame.Position.X.Offset + 310, MainFrame.Position.Y.Scale, MainFrame.Position.Y.Offset)
            FriendsPanel.Position = UDim2.new(MainFrame.Position.X.Scale, MainFrame.Position.X.Offset + 600, MainFrame.Position.Y.Scale, MainFrame.Position.Y.Offset)
        elseif profileResizing then
            local delta = input.Position - profileResizeStart
            local newW = math.max(profileMinSize.X, profileStartSize.X + delta.X)
            local newH = math.max(profileMinSize.Y, profileStartSize.Y + delta.Y)
            ProfilePanel.Size = UDim2.new(0, newW, 0, newH)
        elseif profileDragging then
            local delta = input.Position - profileDragStart
            ProfilePanel.Position = UDim2.new(profileStartPos.X.Scale, profileStartPos.X.Offset + delta.X, profileStartPos.Y.Scale, profileStartPos.Y.Offset + delta.Y)
        elseif friendsDragging then
            local delta = input.Position - friendsDragStart
            FriendsPanel.Position = UDim2.new(friendsStartPos.X.Scale, friendsStartPos.X.Offset + delta.X, friendsStartPos.Y.Scale, friendsStartPos.Y.Offset + delta.Y)
        end
    end
end)

