local function loadFriends(userId)
    for _, c in ipairs(FriendsScroll:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextButton") then c:Destroy() end
    end
    FriendsLoadingLabel.Text = "Loading friends..."
    FriendsLoadingLabel.Visible = true
    FriendsPanel.Visible = true

    task.spawn(function()
        local ok, pages = pcall(function()
            return Players:GetFriendsAsync(userId)
        end)
        if not ok then
            FriendsLoadingLabel.Text = "Failed to load friends."
            return
        end
        FriendsLoadingLabel.Visible = false
        local order = 1
        local function processPage(page)
            for _, friendData in ipairs(page) do
                
                local row = Instance.new("TextButton", FriendsScroll)
                row.Size = UDim2.new(1,0,0,46)
                row.BackgroundColor3 = Color3.fromRGB(22,22,22)
                row.BorderSizePixel = 0
                row.LayoutOrder = order
                row.Text = ""
                row.AutoButtonColor = false
                order = order + 1
                Instance.new("UICorner", row).CornerRadius = UDim.new(0,6)

                local av = Instance.new("ImageLabel", row)
                av.Size = UDim2.new(0,34,0,34)
                av.Position = UDim2.new(0,8,0.5,-17)
                av.BackgroundColor3 = Color3.fromRGB(35,35,35)
                av.Image = ""
                Instance.new("UICorner", av).CornerRadius = UDim.new(0,5)
                getAvatar(friendData.Id, av)

                local dname = Instance.new("TextLabel", row)
                dname.Size = UDim2.new(1,-56,0,18)
                dname.Position = UDim2.new(0,50,0,8)
                dname.BackgroundTransparency = 1
                dname.Text = friendData.DisplayName
                dname.TextColor3 = Color3.new(1,1,1)
