local currentProfileId = nil

local function lookupPlayer(query)
    StatusLabel.Text = "Searching..."
    DisplayNameLabel.Text = ""
    UsernameLabel.Text = ""
    IDLabel.Text = ""
    FriendsLabel.Text = ""
    AvatarImg.Image = ""
    ProfileBtn.Visible = false
    currentProfileId = nil

    local userId = tonumber(query)

   
    if not userId then
        local ok, result = pcall(function()
            return Players:GetUserIdFromNameAsync(query)
        end)
        if ok then
            userId = result
        else
            StatusLabel.Text = "User not found."
            return
        end
    end

    
    local ok1, displayName = pcall(function() return Players:GetNameFromUserIdAsync(userId) end)
    if not ok1 then StatusLabel.Text = "User not found." return end

    
    local thumbUrl = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. userId .. "&width=48&height=48&format=png"
    AvatarImg.Image = thumbUrl

    
    local friendCount = "?"
    local ok2, flist = pcall(function() return Players:GetFriendsAsync(userId) end)
    if ok2 then
        local count = 0
        for _ in flist:GetCurrentPage() do count = count + 1 end
        friendCount = tostring(count) .. (flist.IsFinished and "" or "+")
    end

    StatusLabel.Text = ""
    DisplayNameLabel.Text = displayName
    UsernameLabel.Text = "@" .. displayName
    IDLabel.Text = "User ID: " .. tostring(userId)
    FriendsLabel.Text = "Friends: " .. friendCount
    currentProfileId = userId
    ProfileBtn.Visible = true
end

