RunService.RenderStepped:Connect(function(dt)
    local t = tick()
    
    
    config.intensity = config.active and math.min(config.intensity + dt * 0.5, 1) or math.max(config.intensity - dt * 0.5, 0)
    
    if config.intensity > 0 then
        
        config.hue = (t * 0.4) % 1
        cc.TintColor = Color3.new(1,1,1):Lerp(Color3.fromHSV(config.hue, 0.8, 1), config.intensity)
        
        
        local roll = math.sin(t * 2) * (0.35 * config.intensity)
        camera.CFrame = camera.CFrame * CFrame.Angles(0, 0, roll)
        
        
        camera.FieldOfView = config.originalFOV + (math.sin(t * 1.5) * (25 * config.intensity))
    else
        
        cc.TintColor = Color3.new(1, 1, 1)
        camera.FieldOfView = config.originalFOV
    end

    
    if topLine and bottomLine and leftLine and rightLine then
        local pulse = (math.sin(t * 3) + 1) / 2 

        local color = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(255, 80, 80), pulse)

        topLine.BackgroundColor3 = color
        bottomLine.BackgroundColor3 = color
        leftLine.BackgroundColor3 = color
        rightLine.BackgroundColor3 = color
    end
end)
