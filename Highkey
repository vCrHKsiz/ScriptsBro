local function createKey(text, x, y, w, h, keyCodeName)
    local key = Instance.new("TextLabel")
    key.Text = text
    key.Size = UDim2.new(0, w or 28, 0, h or 28)
    key.Position = UDim2.new(0, x, 0, y)
    key.BackgroundColor3 = config.key_bg
    key.TextColor3 = Color3.new(1,1,1)
    key.Font = Enum.Font.GothamBold
    key.TextSize = 10
    key.Parent = Board
    Instance.new("UICorner", key).CornerRadius = UDim.new(0, 4)
    if keyCodeName then keyObjects[keyCodeName] = key end
    return key
end

